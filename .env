# APP CONFIG
NODE_ENV=development
PORT=3000
CORS=*
EXPOSE_HEADERS="Content-Type, Authorization"
FRONTEND_URL=http://localhost:3030
SERVER_URL=http://localhost:3000
SERVICE_API_KEY=supersecret

# DATABASE CONFIG
DATABASE_HOST=localhost
DATABASE_PORT=27017
DATABASE_NAME=voluntas
# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
# ElevenLabs
ELEVENLABS_API_KEY=
# Eleven Labs Agent IDs
ELEVENLABS_CONSULTATION_AGENT_ID=agent_9701kj0f9wqce6vsnefrqvw0n24z
ELEVENLABS_PRESENTATION_AGENT_ID=agent_3801kj6vdeg0evk94ntqv864f0d0

# Gemini
GEMINI_API_KEY=

# OpenAI
# Add your key here when testing OpenAI stages.
OPENAI_API_KEY=

# Stage-level LLM routing (provider/model/fallbacks)
# Providers: gemini | openai
# Fallback format: provider:model,provider:model
CLIENT_PROFILE_TOOL_LOOP_PROVIDER=openai
CLIENT_PROFILE_TOOL_LOOP_MODEL=gpt-5.2
CLIENT_PROFILE_TOOL_LOOP_FALLBACKS=gemini:models/gemini-3-pro-preview
CLIENT_PROFILE_SYNTHESIS_PROVIDER=openai
CLIENT_PROFILE_SYNTHESIS_MODEL=gpt-5.2
CLIENT_PROFILE_SYNTHESIS_FALLBACKS=gemini:models/gemini-3-pro-preview
SOLUTION_TOOL_LOOP_PROVIDER=openai
SOLUTION_TOOL_LOOP_MODEL=gpt-5.4
SOLUTION_TOOL_LOOP_FALLBACKS=gemini:models/gemini-3-pro-preview
SOLUTION_SYNTHESIS_PROVIDER=openai
SOLUTION_SYNTHESIS_MODEL=gpt-5.2
SOLUTION_SYNTHESIS_FALLBACKS=gemini:models/gemini-3-pro-preview
POLICY_UI_PROVIDER=openai
POLICY_UI_MODEL=gpt-5.2
POLICY_UI_FALLBACKS=gemini:models/gemini-3-pro-preview
AI_COMPANION_PROVIDER=openai
AI_COMPANION_MODEL=gpt-4.1-mini
AI_COMPANION_FALLBACKS=gemini:models/gemini-3-pro-preview

# NeoEngine
PYTHON_NEO_ENGINE_URL=http://localhost:8000
